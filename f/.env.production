# Production = same-origin. Nginx serves the built dist/ and reverse-proxies
# /api and /socket.io to the Node backend (localhost:2222).
# Empty base => requests are relative to the page origin:
#   `${VITE_BACKEND_URL}/api/auth/login` -> /api/auth/login
#   io('') -> connects to the page origin (/socket.io)
VITE_BACKEND_URL=
VITE_SOCKET_URL=
